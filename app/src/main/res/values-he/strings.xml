    <string name="settings_map_operations_title">פעולות מפה</string>
    <string name="settings_map_operations_desc">כוונן את זמן ההמתנה, בקרות הזום וגודל הסמן.</string>
    <string name="settings_help_map_operations">הגדר כמה זמן נקודה בתור ממתינה לפני שמירה אוטומטית, מתי בקרות הזום מוצגות ואיזה גודל צריכים להיות הסמנים. הקש סיום כשההתנהגות ברורה.</string>
    <string name="settings_photo_compression_title">דחיסת תמונות</string>
    <string name="settings_photo_compression_desc">הגדר את התנהגות דחיסת התמונות כברירת מחדל.</string>
    <string name="settings_help_photo_compression">בחר אם התמונות שומרות על האיכות המקורית או נדחסות כברירת מחדל. במצב דחוס אפשר לבחור פורמט ואיכות.</string>
    <string name="settings_cache_title">מטמון מפה</string>
    <string name="settings_cache_desc">בחר מקור אריחים ומדיניות מטמון למפה.</string>
    <string name="settings_help_cache">בחר את מקור האריחים ואת מידת השמירה של אריחים. ניקוי המטמון מסיר אריחים שאינם חלק מהאזורים שהורדו.</string>
    <string name="settings_download_title">הורדות</string>
    <string name="settings_download_desc">בחר מקור הורדה ונהל אזורים שמורים.</string>
    <string name="settings_help_download">בחר שרת אריחים להורדות המוניות, הפעל את מוריד המפה, ונקה או הסר כפילויות מאזורים שמורים מהמסך הזה.</string>
