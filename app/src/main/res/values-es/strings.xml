    <string name="settings_sensors_title">Sensores</string>
    <string name="settings_sensors_desc">Configura cada interruptor de captura de sensores.</string>
    <string name="settings_help_sensors">Activa o desactiva cada sensor de forma independiente para los nuevos puntos. La captura de ruido requiere permiso de micrófono.</string>
