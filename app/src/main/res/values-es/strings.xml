    <string name="settings_help_title">Ayuda</string>
    <string name="settings_help_overview">Toca las tarjetas de abajo para abrir los paneles de tema, controles del mapa, compresión de fotos, caché, descargas y etiquetas predeterminadas. Cada pantalla tiene un botón ? con consejos rápidos.</string>
