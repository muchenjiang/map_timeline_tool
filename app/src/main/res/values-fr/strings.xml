    <string name="settings_language_title">Langue</string>
    <string name="language_follow_system">Suivre le système</string>
    <string name="settings_sensors_title">Capteurs</string>
    <string name="settings_sensors_desc">Configurez chaque interrupteur de capture des capteurs.</string>
    <string name="settings_help_sensors">Activez ou désactivez chaque capteur indépendamment pour les nouveaux points. La capture du bruit nécessite l’autorisation microphone.</string>
    <string name="settings_sensor_pressure">Baromètre</string>
    <string name="settings_sensor_ambient_light">Lumière ambiante</string>
    <string name="settings_sensor_accelerometer">Accéléromètre</string>
    <string name="settings_sensor_gyroscope">Gyroscope</string>
    <string name="settings_sensor_magnetometer">Magnétomètre</string>
    <string name="settings_sensor_noise">Bruit (3 s dBFS)</string>
    <string name="settings_noise_collect_label">Capturer 3 secondes de bruit</string>
    <string name="settings_noise_collect_desc">Nécessite l’autorisation microphone. Capturé de façon asynchrone après l’enregistrement du point.</string>
    <string name="settings_map_operations_title">Opérations de carte</string>
    <string name="settings_map_operations_desc">Ajustez le délai, les contrôles de zoom et la taille des marqueurs.</string>
    <string name="settings_help_map_operations">Définissez combien de temps un point en file d’attente attend avant l’enregistrement automatique, quand les contrôles de zoom apparaissent et la taille des marqueurs. Touchez Terminé quand vous avez compris le comportement.</string>
    <string name="settings_photo_compression_title">Compression photo</string>
    <string name="settings_photo_compression_desc">Configurez le comportement de compression photo par défaut.</string>
    <string name="settings_help_photo_compression">Choisissez si les photos gardent leur qualité d’origine ou sont compressées par défaut. En mode compressé, choisissez le format et la qualité.</string>
    <string name="settings_cache_title">Cache de la carte</string>
    <string name="settings_cache_desc">Choisissez une source de tuiles et une politique de cache pour la carte.</string>
    <string name="settings_help_cache">Sélectionnez la source de tuiles en amont et la manière dont l’application conserve les tuiles. Vider le cache supprime les tuiles qui ne font pas partie des zones téléchargées.</string>
    <string name="settings_download_title">Téléchargements</string>
    <string name="settings_download_desc">Choisissez une source de téléchargement et gérez les zones enregistrées.</string>
    <string name="settings_help_download">Sélectionnez un serveur de tuiles pour les téléchargements en masse, lancez le téléchargeur de carte et nettoyez ou dédupliquez les zones enregistrées depuis cet écran.</string>
    <string name="settings_backup_restore_title">Sauvegarde et restauration</string>
    <string name="settings_backup_restore_desc">Importez ou exportez des données, et partagez une sauvegarde ZIP complète.</string>
    <string name="settings_help_backup_restore">Utilisez cet écran pour importer ou exporter des fichiers CSV, GeoJSON, KML, KMZ ou ZIP. Vous pouvez aussi créer localement une sauvegarde ZIP complète puis ouvrir la feuille de partage système pour l’envoyer vers d’autres applications ou des services cloud.</string>
