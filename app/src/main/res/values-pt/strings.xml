    <string name="settings_help_title">Ajuda</string>
    <string name="settings_help_overview">Toque nos cartões abaixo para abrir os painéis de tema, controles do mapa, compressão de fotos, cache, downloads e tags padrão. Cada tela tem um botão ? com dicas rápidas.</string>
